# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here    # NEVER expose publicly

# ── Stripe ───────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                          # From Stripe webhook config
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (create products in Stripe dashboard first)
STRIPE_PRICE_COLLECTOR_MONTHLY=price_...
STRIPE_PRICE_COLLECTOR_ANNUAL=price_...
STRIPE_PRICE_ADVISOR_MONTHLY=price_...
STRIPE_PRICE_ADVISOR_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://artfomo.vercel.app
